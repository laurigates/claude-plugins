{
  "name": "python-plugin",
  "version": "1.5.0",
  "description": "Python development ecosystem - uv, ruff, pytest, packaging, type checking",
  "author": {
    "name": "Lauri Gates"
  },
  "repository": "https://github.com/laurigates/claude-plugins",
  "license": "MIT",
  "keywords": [
    "python",
    "uv",
    "ruff",
    "pytest",
    "packaging",
    "type-checking",
    "basedpyright",
    "ty",
    "astral"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/pip-to-uv.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
