# Git attributes — merge, diff, and checkout behavior by path.
# See .claude/rules/ and docs; companion to scripts/resolve-additive-conflicts.py
# and .github/workflows/auto-resolve-conflicts.yml.

# --- Line endings -----------------------------------------------------------
# Normalize all text to LF in the repo. Protects the ~200 shell hooks/check
# scripts from CRLF corruption (a CRLF shebang line silently breaks execution).
# No-op on the current tree (already 100% LF), so it adds safety without churn.
* text=auto eol=lf
*.sh text eol=lf

# --- Append-only union merges ----------------------------------------------
# These files are append-only logs/tables: every bug-fix PR adds a row, and
# parallel PRs therefore conflict on the *same anchor* with disjoint additions.
# The built-in `union` driver concatenates both sides' additions with no
# conflict markers and no LLM. ONLY safe for genuinely append-only files —
# never apply to code or JSON (union duplicates edited lines / breaks syntax).
.claude/rules/regression-testing.md merge=union

# --- Generated files (GitHub linguist) -------------------------------------
# Collapse in PR diffs and exclude from language stats. These are build output
# or tool-owned — reviewers should not wade through their churn, and a conflict
# in them is resolved by regenerating, not by hand-merging. (linguist-generated
# only affects GitHub's display; it changes no merge behavior — so it is safe
# even where `merge=union` would be wrong.)
**/CHANGELOG.md linguist-generated=true
.release-please-manifest.json linguist-generated=true
# Compiled from each SKILL.md by git-repo-agent's prompts/compiler.py.
git-repo-agent/src/git_repo_agent/prompts/generated/** linguist-generated=true
# Rendered from the committed .d2 sources (the .d2 is the reviewable artifact).
docs/diagrams/*.svg linguist-generated=true
# uv-managed lockfile (never union-merge a lockfile — regenerate on conflict).
vault-agent/uv.lock linguist-generated=true
