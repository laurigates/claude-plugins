{
  "name": "feedback-plugin",
  "version": "1.3.2",
  "description": "Session feedback analysis - capture skill bugs as GitHub issues and learn from weekly friction across sessions",
  "author": {
    "name": "Lauri Gates",
    "url": "https://github.com/laurigates"
  },
  "repository": "https://github.com/laurigates/claude-plugins",
  "license": "MIT",
  "keywords": [
    "feedback",
    "session-analysis",
    "skill-quality",
    "github-issues",
    "continuous-improvement",
    "friction-learner"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-open-pr.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
