{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "project-plugin",
  "version": "1.16.0",
  "description": "Project initialization and management - setup, modernization, and continuous development workflows",
  "author": {
    "name": "Lauri Gates"
  },
  "repository": "https://github.com/laurigates/claude-plugins",
  "license": "MIT",
  "keywords": [
    "project",
    "initialization",
    "setup",
    "modernization",
    "tdd",
    "workflow",
    "changelog",
    "maintenance",
    "distill",
    "insights",
    "knowledge-capture"
  ],
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "args": [
              "bash",
              "${CLAUDE_PLUGIN_ROOT}/hooks/project-distill-nudge.sh"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  }
}
